# Groq API key get from console.groq.com (free tier available)
GROQ_API_KEY=gsk_...

# House wallet private key (testnet only, funds the rewards)
# Generate with: offckb account list
# Fund from: https://faucet.nervos.org
HOUSE_PRIVATE_KEY=0x...

# Optional: override testnet RPC
# CKB_TESTNET_RPC=https://testnet.ckb.dev/rpc

# Fiber node RPC for Checkpoint 4/5 verification (optional for now)
# FIBER_NODE_RPC_URL=http://127.0.0.1:8227
